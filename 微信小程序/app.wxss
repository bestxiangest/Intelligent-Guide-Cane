page {
  min-height: 100vh;
  background: #F4F7F5;
  color: #17231F;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  font-size: inherit;
  line-height: normal;
  background: transparent;
}

button::after {
  border: none;
}
